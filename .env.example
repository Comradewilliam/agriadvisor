# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=agridb
DB_USER=root
DB_PASS=root
DB_CHARSET=utf8mb4

# App (used for OpenRouter HTTP-Referer header)
APP_URL=https://your-ngrok-or-domain.com
# Optional — protects /internal/sms/diagnose
USSD_ASYNC_SECRET=change-me-to-a-long-random-string

# Africa's Talking — https://africastalking.com
AT_USERNAME=sandbox
AT_API_KEY=
AT_SANDBOX=1
# REQUIRED for two-way SMS — short code farmers text (SMS → Short Codes in AT dashboard)
AT_SHORT_CODE=
# One-way SMS sender (welcome, OTP, alerts, broadcasts)
AT_BULK_SENDER_ID=AFRICASTKNG
# Skip webhook HMAC check during local testing
AT_SKIP_WEBHOOK_VERIFY=1
# SSL: set 0 on MAMP/Windows if curl fails with "unable to get local issuer certificate"
AT_SSL_VERIFY=0

# OpenRouter — https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# WeatherAPI — https://www.weatherapi.com/
WEATHER_API_KEY=
